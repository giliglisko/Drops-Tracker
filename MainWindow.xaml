<Window x:Class="Drops_Tracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Drops_Tracker"
        mc:Ignorable="d"
        Title="MapleStory Weekly Boss Drop Tracker"
        Height="850" Width="1400"
        MinHeight="600" MinWidth="1000"
        Background="{DynamicResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource PrimaryBrush}" Padding="15,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="MapleStory" FontSize="18" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text=" Drop Tracker" FontSize="18" FontWeight="Light" Foreground="#FFFFFFCC"/>
            </StackPanel>
        </Border>

        <!-- Tab Control -->
        <TabControl Grid.Row="1" Margin="10,8,10,10" x:Name="MainTabControl" SelectionChanged="MainTabControl_SelectionChanged">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="TabBorder" Background="{DynamicResource TabInactiveBrush}" CornerRadius="8,8,0,0"
                                        Padding="20,10" Margin="0,0,2,0">
                                    <ContentPresenter x:Name="ContentSite" ContentSource="Header"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="False">
                                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Style>
            </TabControl.Resources>

            <!-- Tracker Tab -->
            <TabItem Header="Weekly Tracker">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Main Calendar Grid -->
                    <Border Grid.Row="0" Margin="0,5,0,5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Week Navigation -->
                            <Border Grid.Row="0" Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="8" Margin="0,0,0,5">
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="1" BlurRadius="6" Opacity="0.1" Color="Black"/>
                                </Border.Effect>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="&lt;" Style="{DynamicResource NavButton}" Click="PrevWeek_Click" ToolTip="Previous Week"/>
                                    <Button Content="&gt;" Style="{DynamicResource NavButton}" Click="NextWeek_Click" ToolTip="Next Week" Margin="5,0,0,0"/>
                                    <Button Content="Today" Style="{DynamicResource PrimaryButton}" Click="GoToToday_Click"
                                            Margin="15,0,0,0" Padding="12,6"/>
                                </StackPanel>
                            </Border>

                            <!-- Calendar ScrollViewer -->
                            <Border Grid.Row="1" Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="3" AllowDrop="True">
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="1" BlurRadius="6" Opacity="0.1" Color="Black"/>
                                </Border.Effect>
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" AllowDrop="True" Padding="0,0,10,10">
                                    <Grid x:Name="CalendarGrid" AllowDrop="True">
                                        <!-- Calendar will be built dynamically -->
                                    </Grid>
                                </ScrollViewer>
                            </Border>

                            <!-- Empty State -->
                            <Border Grid.Row="1" x:Name="NoDataPanel" Background="{DynamicResource CardBrush}" CornerRadius="8" Visibility="Collapsed">
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="1" BlurRadius="6" Opacity="0.1" Color="Black"/>
                                </Border.Effect>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Border Width="80" Height="80" CornerRadius="40" Background="{DynamicResource CharacterCellBrush}" Margin="0,0,0,20">
                                        <TextBlock Text="+" FontSize="40" Foreground="{DynamicResource PrimaryBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="No characters yet" FontSize="20" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Click '+ New Character' tab to get started!" FontSize="14"
                                               Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Inventory Panel -->
                    <Border Grid.Row="1" Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="10">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="1" BlurRadius="6" Opacity="0.1" Color="Black"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                                <Border Width="24" Height="24" CornerRadius="6" Background="{DynamicResource PrimaryBrush}" Margin="0,0,8,0">
                                    <TextBlock Text="*" FontSize="14" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Item Inventory" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="  |  Drag items to calendar cells" FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                          MaxHeight="115">
                                <ItemsControl x:Name="InventoryPanel" Margin="0,0,0,18">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </ScrollViewer>

                            <TextBlock x:Name="NoItemsText" Grid.Row="1"
                                       Text="No items found. Add image files (.png, .jpg) to the 'assets' folder."
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontStyle="Italic" HorizontalAlignment="Center"
                                       Margin="0,15,0,15" Visibility="Collapsed"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Overview Tab -->
            <TabItem Header="Overview">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="0,15,0,0">
                    <StackPanel>
                        <!-- Disclaimer -->
                        <TextBlock Text="* Grindstone items are shown but not included in totals."
                                   FontSize="11" FontStyle="Italic"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,0,0,10"/>

                        <!-- Year Selector -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="12" Padding="15" Margin="0,0,0,15">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="1" BlurRadius="6" Opacity="0.1" Color="Black"/>
                            </Border.Effect>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="&lt;" Style="{DynamicResource NavButton}" Click="PrevYear_Click" ToolTip="Previous Year"/>
                                <TextBlock x:Name="YearDisplay"
                                           Text="2024"
                                           FontSize="18" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"
                                           VerticalAlignment="Center"
                                           Margin="25,0"/>
                                <Button Content="&gt;" Style="{DynamicResource NavButton}" Click="NextYear_Click" ToolTip="Next Year"/>
                            </StackPanel>
                        </Border>

                        <!-- Yearly Overview -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="1" BlurRadius="6" Opacity="0.1" Color="Black"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="Yearly Overview" FontSize="18" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" Margin="0,0,0,15"/>
                                <Grid x:Name="YearlyOverviewGrid">
                                    <!-- Will be populated dynamically -->
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Monthly Overview -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="12" Padding="20">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="1" BlurRadius="6" Opacity="0.1" Color="Black"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="Monthly Breakdown" FontSize="18" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" Margin="0,0,0,15"/>
                                <Grid x:Name="MonthlyOverviewGrid">
                                    <!-- Will be populated dynamically -->
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Settings Tab -->
            <TabItem Header="Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,15,0,0">
                    <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                        <!-- Appearance Section -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="1" BlurRadius="6" Opacity="0.1" Color="Black"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="Appearance" FontSize="18" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" Margin="0,0,0,15"/>

                                <!-- Dark Mode Toggle -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Dark Mode" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextBrush}"/>
                                        <TextBlock Text="Switch to a darker color scheme"
                                                   FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <!-- Toggle Switch -->
                                    <Border Grid.Column="1" x:Name="DarkModeToggle"
                                            Width="50" Height="26" CornerRadius="13"
                                            Background="{DynamicResource BorderBrush}"
                                            Cursor="Hand" MouseLeftButtonUp="DarkModeToggle_Click">
                                        <Border x:Name="DarkModeThumb"
                                                Width="22" Height="22" CornerRadius="11"
                                                Background="{DynamicResource CardBrush}" HorizontalAlignment="Left"
                                                Margin="2,0,0,0">
                                            <Border.Effect>
                                                <DropShadowEffect ShadowDepth="1" BlurRadius="2" Opacity="0.2" Color="Black"/>
                                            </Border.Effect>
                                        </Border>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- New Character Tab (acts as button) -->
            <TabItem Header="+ New Character">
                <Border/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
