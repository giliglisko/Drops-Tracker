<Window x:Class="Drops_Tracker.AddCharacterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Character"
        Height="550" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        KeyDown="Window_KeyDown"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="{DynamicResource CardBrush}" CornerRadius="16" Margin="10">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="20" Opacity="0.3" Color="Black"/>
        </Border.Effect>

        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                <Border Width="36" Height="36" CornerRadius="8" Background="{DynamicResource PrimaryBrush}">
                    <TextBlock x:Name="HeaderIconTextBlock" Text="+" FontSize="20" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock x:Name="HeaderTitleTextBlock" Text="Add Character" FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" Margin="12,0,0,0"/>
            </StackPanel>

            <!-- Character Name -->
            <Label Grid.Row="1" Content="Character Name" Margin="0,0,0,3" Padding="0"/>
            <TextBox Grid.Row="2" x:Name="NameTextBox" Margin="0,0,0,12"/>

            <!-- Class -->
            <Label Grid.Row="3" Content="Class" Margin="0,0,0,3" Padding="0"/>
            <TextBox Grid.Row="4" x:Name="ClassTextBox" Margin="0,0,0,12"/>

            <!-- Level -->
            <Label Grid.Row="5" Content="Level" Margin="0,0,0,3" Padding="0"/>
            <TextBox Grid.Row="6" x:Name="LevelTextBox" Margin="0,0,0,15"/>

            <!-- Buttons -->
            <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button x:Name="CancelButton" Content="Cancel" Style="{DynamicResource SecondaryButton}"
                        Click="Cancel_Click" Margin="0,0,10,0" Width="100"/>
                <Button x:Name="AddButton" Content="Add Character" Style="{DynamicResource PrimaryButton}"
                        Click="Add_Click" Width="130"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
